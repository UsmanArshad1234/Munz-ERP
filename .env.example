APP_NAME=MUZN_ERP
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=muzn_erp
DB_USERNAME=root
DB_PASSWORD=

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Sanctum / Auth ────────────────────────────────────────────────────────────
# Token expiry in minutes (e.g. 10080 = 7 days). Leave blank = never expires.
SANCTUM_TOKEN_EXPIRY=10080
SANCTUM_TOKEN_PREFIX=

# ── File Storage ──────────────────────────────────────────────────────────────
FILESYSTEM_DISK=public
# Run after deploy: php artisan storage:link

# ── Cache / Queue ─────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
QUEUE_CONNECTION=database
CACHE_STORE=database

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@muzn.ae"
MAIL_FROM_NAME="${APP_NAME}"

# ── Redis (optional) ─────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── AWS S3 (optional — for cloud file storage) ────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=me-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
